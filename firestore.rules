rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================
    // ⚠️ ADDING NEW COLLECTIONS? READ THIS FIRST!
    // =============================================
    //
    // CRITICAL: Every Firestore collection MUST have Security Rules.
    // Without rules, even Super Admin will be blocked from access.
    //
    // TEMPLATE FOR NEW COLLECTIONS:
    //
    //   // =============================================
    //   // [collection_name] collection
    //   // =============================================
    //   match /[collection_name]/{docId} {
    //     // All active users can read
    //     allow read: if isActiveUser();
    //
    //     // Create/Update: super_admin, operations_admin
    //     allow create: if hasRole(['super_admin', 'operations_admin']);
    //     allow update: if hasRole(['super_admin', 'operations_admin']);
    //     allow delete: if hasRole(['super_admin', 'operations_admin']);
    //   }
    //
    // CUSTOMIZATION:
    // - Adjust roles based on feature (e.g., finance, procurement)
    // - Add project assignment checks for operations_user filtering
    // - Restrict delete if needed (audit collections should be append-only)
    //
    // WHAT HAPPENS IF YOU FORGET:
    // - Firestore denies all access by default (no implicit admin access)
    // - You'll get "Missing or insufficient permissions" errors
    // - Even Super Admin will be blocked (Phase 11 issue)
    //
    // SEE: CLAUDE.md section "Add New View" for full checklist
    // =============================================

    // =============================================
    // HELPER FUNCTIONS
    // =============================================

    // Is the request from a signed-in user?
    function isSignedIn() {
      return request.auth != null;
    }

    // Read the current user's document. Cached per evaluation -- one billable read.
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Is the user's status 'active'?
    function isActiveUser() {
      return isSignedIn() && getUserData().status == 'active';
    }

    // Does the user have one of the listed roles?
    function hasRole(roles) {
      return isActiveUser() && getUserData().role in roles;
    }

    // Does the user have a specific role?
    function isRole(role) {
      return hasRole([role]);
    }

    // Check if an operations_user is assigned to a given project_code.
    // Only call this after confirming role is operations_user.
    function isAssignedToProject(projectCode) {
      return getUserData().all_projects == true ||
             projectCode in getUserData().assigned_project_codes;
    }

    // Helper for legacy data: check if doc has no project_code or empty project_code
    function isLegacyOrAssigned(projectCode) {
      return !('project_code' in resource.data) ||
             resource.data.project_code == '' ||
             isAssignedToProject(projectCode);
    }

    // Check if a services_user is assigned to a given service_code.
    // Only call this after confirming role is services_user (short-circuit guard).
    // all_services == true means unrestricted access (mirrors all_projects for operations_admin).
    function isAssignedToService(serviceCode) {
      return getUserData().all_services == true ||
             serviceCode in getUserData().assigned_service_codes;
    }

    // =============================================
    // SECURITY AUDIT — 2026-03-01 (Phase 49, Plan 02)
    // =============================================
    // Audit scope: 12 collections + 2 subcollections, all 7 application roles
    // Roles: super_admin, operations_admin, operations_user,
    //        services_admin, services_user, finance, procurement
    //
    // KEY FINDINGS & FIXES:
    // 1. [FIXED] users.update self-update allowed role/status field changes → role escalation risk
    //    Fix: Field-level restriction on self-update — role, status, invitation_code are now admin-only
    // 2. [DOCUMENTED] invitation_codes open read/update → documented as ACCEPTED RISK (see block below)
    // 3. [VERIFIED] All other collections follow least-privilege; no unauthenticated write paths found
    // 4. [VERIFIED] operations_user cannot delete MRFs (delete requires operations_admin or super_admin)
    // 5. [VERIFIED] services_user cannot create PRs (create requires super_admin, operations_admin, procurement)
    // 6. [VERIFIED] Role cross-contamination blocked: services_* cannot affect operations_* and vice versa
    //    (list/get rules scope by role; write rules are explicit about which roles apply)
    // =============================================

    // =============================================
    // users collection
    // =============================================
    match /users/{userId} {
      // Get: own doc OR super_admin OR (operations_admin AND target is operations_user) OR (services_admin AND target is services_user)
      allow get: if isSignedIn() && (
        request.auth.uid == userId ||
        isRole('super_admin') ||
        (isRole('operations_admin') && get(/databases/$(database)/documents/users/$(userId)).data.role == 'operations_user') ||
        (isRole('services_admin') && get(/databases/$(database)/documents/users/$(userId)).data.role == 'services_user')
      );

      // List: super_admin OR operations_admin OR services_admin
      // Note: operations_admin and services_admin list access must be filtered client-side to their respective user roles
      allow list: if isRole('super_admin') || isRole('operations_admin') || isRole('services_admin');

      // Phase 84 D-12: allow any signed-in user to read super_admin user docs
      // Required for createNotificationForRoles({roles:['super_admin']}) called from register.js
      // This exposes only name/email to other internal users — super_admin docs are not sensitive to authenticated staff
      allow read: if isSignedIn() && resource.data.role == 'super_admin';

      // Create: signed-in user creating own doc AND status is 'pending'
      allow create: if isSignedIn() &&
                       request.auth.uid == userId &&
                       request.resource.data.status == 'pending';

      // Update: super_admin OR (operations_admin AND target is operations_user) OR (services_admin AND target is services_user) OR own doc
      // SEC-AUDIT: Self-update is restricted to safe fields only.
      // A user updating their own doc CANNOT change role or status — those are admin-only fields.
      // Without this restriction, any user could escalate their own role to super_admin.
      allow update: if isSignedIn() && (
        isRole('super_admin') ||
        (isRole('operations_admin') && get(/databases/$(database)/documents/users/$(userId)).data.role == 'operations_user') ||
        (isRole('services_admin') && get(/databases/$(database)/documents/users/$(userId)).data.role == 'services_user') ||
        (request.auth.uid == userId &&
         !('role' in request.resource.data) &&
         !('status' in request.resource.data) &&
         !('invitation_code' in request.resource.data))
      );

      // Delete: super_admin can delete deactivated users only (two-step safety)
      allow delete: if isRole('super_admin') &&
                       get(/databases/$(database)/documents/users/$(userId)).data.status == 'deactivated';
    }

    // =============================================
    // role_templates collection
    // =============================================
    match /role_templates/{roleId} {
      // All active users can read role templates (permissions module needs this)
      allow read: if isActiveUser();

      // Only Super Admin can modify role templates
      allow write: if isRole('super_admin');
    }

    // =============================================
    // invitation_codes collection
    // =============================================
    // ACCEPTED RISK (intentional design — documented in CONTEXT.md):
    // read and update are open (allow: true) because:
    //   1. Codes are random UUID-like strings — enumeration attacks are infeasible
    //   2. Reading a code only tells you it exists; you still need Firebase Auth + admin approval
    //   3. Unauthenticated users must validate the code BEFORE creating their Firebase Auth account
    //   4. After creating an Auth account, they mark the code 'used' (unauthenticated at that moment)
    //   5. Real security is in the user approval workflow: new users start as 'pending' and require
    //      admin activation before gaining any system access
    // Mitigation: codes are single-use and become 'used' after registration; admins can delete expired codes
    match /invitation_codes/{codeId} {
      // ACCEPTED RISK: Anyone can read — unauthenticated users validate codes during registration
      allow read: if true;

      // Super Admin creates codes
      allow create: if isRole('super_admin');

      // ACCEPTED RISK: Anyone can update — unauthenticated users mark code as used after Auth account created
      allow update: if true;

      // Delete: super_admin can delete (for expired code cleanup)
      allow delete: if isRole('super_admin');
    }

    // =============================================
    // projects collection
    // =============================================
    match /projects/{projectId} {
      // All active users can read
      allow read: if isActiveUser();

      // Phase 78 D-01: clientless projects allowed (client_id and project_code may be null on create — code issued later when client is assigned)
      // Create: super_admin, operations_admin
      allow create: if hasRole(['super_admin', 'operations_admin']);

      // Update: super_admin, operations_admin, finance
      // Phase 78 D-12: once project_code is issued (non-null), client_id/client_code/project_code are PERMANENTLY LOCKED at the DB level.
      // Pre-issuance (project_code == null): all updates allowed (lets runCodeIssuance set the codes).
      // Post-issuance: updates allowed ONLY if the request preserves project_code, client_id, and client_code unchanged.
      allow update: if hasRole(['super_admin', 'operations_admin', 'finance']) &&
        (resource.data.project_code == null ||
          (request.resource.data.project_code == resource.data.project_code &&
           request.resource.data.client_id == resource.data.client_id &&
           request.resource.data.client_code == resource.data.client_code));

      // Delete: super_admin, operations_admin
      allow delete: if hasRole(['super_admin', 'operations_admin']);

      // edit_history subcollection (Phase 25 - append-only audit trail)
      match /edit_history/{entryId} {
        // Read: all active users (consistent with project read access)
        allow read: if isActiveUser();

        // Create: roles that can update projects or services (services reuse this subcollection)
        allow create: if hasRole(['super_admin', 'operations_admin', 'services_admin', 'finance']);

        // Append-only: no updates or deletes allowed
        allow update: if false;
        allow delete: if false;
      }
    }

    // =============================================
    // clients collection
    // =============================================
    match /clients/{clientId} {
      // All active users can read
      allow read: if isActiveUser();

      // Create: super_admin, operations_admin, services_admin
      allow create: if hasRole(['super_admin', 'operations_admin', 'services_admin']);

      // Update: super_admin, operations_admin, services_admin
      allow update: if hasRole(['super_admin', 'operations_admin', 'services_admin']);

      // Delete: super_admin, operations_admin, services_admin
      allow delete: if hasRole(['super_admin', 'operations_admin', 'services_admin']);
    }

    // =============================================
    // mrfs collection
    // =============================================
    match /mrfs/{mrfId} {
      // Get: all active users
      allow get: if isActiveUser();

      // List: cross-dept roles unrestricted; operations_user project-scoped; services_user unrestricted
      // NOTE: services_user was previously scoped to assigned services only, but this blocked
      // generateMRFId() in mrf-form.js from doing an unscoped getDocs(mrfs) query needed to
      // generate the next MRF sequence number. services_user list is now unrestricted since
      // they can already 'get' any individual MRF doc and MRF metadata is not sensitive.
      allow list: if isActiveUser() && (
        hasRole(['super_admin', 'operations_admin', 'services_admin', 'services_user', 'finance', 'procurement']) ||
        (isRole('operations_user') && isLegacyOrAssigned(resource.data.project_code))
      );

      // Create: all roles that can submit MRFs (operations and services dept users)
      allow create: if hasRole(['super_admin', 'operations_admin', 'operations_user', 'services_admin', 'services_user', 'procurement']);

      // Update: super_admin, dept admins, finance, procurement
      allow update: if hasRole(['super_admin', 'operations_admin', 'services_admin', 'finance', 'procurement']);

      // Delete: super_admin, operations_admin, procurement
      allow delete: if hasRole(['super_admin', 'operations_admin', 'procurement']);
    }

    // =============================================
    // prs collection
    // =============================================
    match /prs/{prId} {
      // Get: all active users
      allow get: if isActiveUser();

      // List: cross-dept roles unrestricted; operations_user project-scoped; services_admin unrestricted (tracks their MRFs); services_user service-scoped
      allow list: if isActiveUser() && (
        hasRole(['super_admin', 'operations_admin', 'services_admin', 'finance', 'procurement']) ||
        (isRole('operations_user') && isLegacyOrAssigned(resource.data.project_code)) ||
        (isRole('services_user') && isAssignedToService(resource.data.service_code))
      );

      // Create: super_admin, operations_admin, procurement
      allow create: if hasRole(['super_admin', 'operations_admin', 'procurement']);

      // Update: super_admin, dept admins, finance, procurement
      allow update: if hasRole(['super_admin', 'operations_admin', 'services_admin', 'finance', 'procurement']);

      // Delete: super_admin, operations_admin, procurement
      allow delete: if hasRole(['super_admin', 'operations_admin', 'procurement']);
    }

    // =============================================
    // pos collection
    // =============================================
    match /pos/{poId} {
      // Get: all active users
      allow get: if isActiveUser();

      // List: cross-dept roles unrestricted; operations_user project-scoped; services_admin unrestricted; services_user service-scoped
      allow list: if isActiveUser() && (
        hasRole(['super_admin', 'operations_admin', 'services_admin', 'finance', 'procurement']) ||
        (isRole('operations_user') && isLegacyOrAssigned(resource.data.project_code)) ||
        (isRole('services_user') && isAssignedToService(resource.data.service_code))
      );

      // Create: super_admin, finance (Finance issues POs after approving PRs)
      allow create: if hasRole(['super_admin', 'finance']);

      // Update: super_admin, finance, procurement
      allow update: if hasRole(['super_admin', 'finance', 'procurement']);

      // Delete: super_admin only
      allow delete: if hasRole(['super_admin']);
    }

    // =============================================
    // transport_requests collection
    // =============================================
    match /transport_requests/{trId} {
      // Get: all active users
      allow get: if isActiveUser();

      // List: cross-dept roles unrestricted; operations_user project-scoped; services_user service-scoped
      allow list: if isActiveUser() && (
        hasRole(['super_admin', 'operations_admin', 'services_admin', 'finance', 'procurement']) ||
        (isRole('operations_user') && isLegacyOrAssigned(resource.data.project_code)) ||
        (isRole('services_user') && isAssignedToService(resource.data.service_code))
      );

      // Create: super_admin, dept admins, dept users, procurement
      allow create: if hasRole(['super_admin', 'operations_admin', 'operations_user', 'services_admin', 'services_user', 'procurement']);

      // Update: super_admin, dept admins, finance, procurement
      allow update: if hasRole(['super_admin', 'operations_admin', 'services_admin', 'finance', 'procurement']);

      // Delete: super_admin, dept admins, procurement
      allow delete: if hasRole(['super_admin', 'operations_admin', 'procurement']);
    }

    // =============================================
    // suppliers collection
    // =============================================
    match /suppliers/{supplierId} {
      // All active users can read
      allow read: if isActiveUser();

      // Create/Update/Delete: super_admin, procurement
      allow create: if hasRole(['super_admin', 'procurement']);
      allow update: if hasRole(['super_admin', 'procurement']);
      allow delete: if hasRole(['super_admin', 'procurement']);
    }

    // =============================================
    // deleted_mrfs collection (soft-delete archive)
    // =============================================
    match /deleted_mrfs/{deletedMrfId} {
      // Read: super_admin, operations_admin only
      allow read: if hasRole(['super_admin', 'operations_admin']);

      // Create: super_admin, operations_admin, procurement (append when MRF is soft-deleted)
      allow create: if hasRole(['super_admin', 'operations_admin', 'procurement']);

      // No update or delete - archive is append-only
      allow update: if false;
      allow delete: if false;
    }

    // =============================================
    // deleted_users collection (user deletion audit trail)
    // =============================================
    match /deleted_users/{userId} {
      // Read: any signed-in user can check if their account was deleted (auth check)
      // Super Admin can read all for audit purposes
      allow get: if isSignedIn() && (
        request.auth.uid == userId ||
        isRole('super_admin')
      );

      // List: super_admin only (for audit purposes)
      allow list: if isRole('super_admin');

      // Create: super_admin only (when deleting a user)
      allow create: if isRole('super_admin');

      // No update or delete - archive is append-only
      allow update: if false;
      allow delete: if false;
    }

    // =============================================
    // services collection
    // =============================================
    match /services/{serviceId} {
      // Get (single document): super_admin, services roles, finance, procurement, operations_admin
      // operations_admin needs get access to support generateProjectCode() which queries
      // both projects and services to avoid sequence number collisions (CODE-01).
      // services_user can get individual docs — more permissive than list.
      allow get: if hasRole(['super_admin', 'operations_admin', 'services_admin', 'services_user', 'finance', 'procurement']);

      // List (collection query): scoped by assignment for services_user
      // operations_admin included so generateProjectCode() / generateServiceCode() can
      // query the services collection when creating a new project (collision check).
      // CRITICAL: isAssignedToService() is ONLY called when isRole('services_user') is true
      // (short-circuit || prevents accessing assigned_service_codes on non-services_user docs)
      allow list: if isActiveUser() && (
        hasRole(['super_admin', 'operations_admin', 'services_admin', 'finance', 'procurement']) ||
        (isRole('services_user') && isAssignedToService(resource.data.service_code))
      );

      // Create: super_admin and services_admin only (SEC-04: services_user CANNOT write)
      allow create: if hasRole(['super_admin', 'services_admin']);

      // Update: super_admin and services_admin unrestricted; services_user scoped to assigned services
      allow update: if hasRole(['super_admin', 'services_admin']) ||
                       (isRole('services_user') && isAssignedToService(resource.data.service_code));

      // Delete: super_admin and services_admin only
      allow delete: if hasRole(['super_admin', 'services_admin']);

      // edit_history subcollection — append-only audit trail for service edits
      match /edit_history/{entryId} {
        allow read: if hasRole(['super_admin', 'services_admin', 'services_user', 'finance', 'procurement']);
        allow create: if hasRole(['super_admin', 'services_admin', 'services_user']);
        allow update: if false;
        allow delete: if false;
      }
    }

    // =============================================
    // rfps collection - Request for Payment
    // =============================================
    match /rfps/{rfpId} {
      // All active users can read (procurement sees RFP status on PO Tracking)
      allow read: if isActiveUser();

      // Create: procurement submits RFPs
      allow create: if hasRole(['super_admin', 'procurement']);

      // Update: finance records payments (arrayUnion on payment_records); procurement can correct pre-submission fields
      allow update: if hasRole(['super_admin', 'finance', 'procurement']);

      // Delete: super_admin or procurement (cancel mis-filed RFPs with zero payments; client-side payment guard enforced)
      allow delete: if hasRole(['super_admin', 'procurement']);
    }

    // =============================================
    // notifications collection (Phase 83 — NOTIF-13)
    // =============================================
    // Per-user in-app notifications. Each user only touches their own.
    // Schema (D-05): user_id, type, message, link, source_collection, source_id,
    //                actor_id, read (bool), read_at, created_at.
    // Create rule (D-18): any active user can write to ANY user's feed (the actor
    //                     writes the recipient's notification — needed because we
    //                     have no Cloud Functions). actor_id pinned to request.auth.uid
    //                     prevents impersonation.
    // Update rule (D-19): only `read` and `read_at` are mutable post-create.
    match /notifications/{docId} {
      allow read: if isActiveUser() && resource.data.user_id == request.auth.uid;

      allow list: if isActiveUser() && resource.data.user_id == request.auth.uid;

      allow create: if isActiveUser()
        && request.resource.data.user_id is string
        && request.resource.data.type is string
        && request.resource.data.message is string
        && request.resource.data.link is string
        && request.resource.data.read == false
        && request.resource.data.actor_id == request.auth.uid;

      allow update: if isActiveUser()
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == resource.data.user_id
        && request.resource.data.type == resource.data.type
        && request.resource.data.message == resource.data.message
        && request.resource.data.link == resource.data.link
        && request.resource.data.created_at == resource.data.created_at
        && request.resource.data.actor_id == resource.data.actor_id;

      allow delete: if isActiveUser() && resource.data.user_id == request.auth.uid;
    }
  }
}
